---
// FilterBar.astro — Estética editorial: labels flotantes, selects con underline, botón dark
import propiedadesRaw from '../data/propiedades.json';
import CustomSelect from './CustomSelect.astro';

const ciudades = [...new Set(propiedadesRaw.filter(p => p.disponible).map(p => p.ciudad))].sort();

const opcionesOperacion = [
  { value: 'alquiler', label: 'Alquiler' },
  { value: 'venta', label: 'Venta' }
];

const opcionesTipo = [
  { value: 'casa', label: 'Casa' },
  { value: 'departamento', label: 'Departamento' },
  { value: 'local', label: 'Local Comercial' }
];

const opcionesCiudad = ciudades.map(c => ({ value: c, label: c }));
---

<div class="flex flex-col md:flex-row items-stretch md:items-end gap-5 md:gap-0 select-none">

  <!-- Operación -->
  <div class="flex-1 flex flex-col border-b border-brand-dark/20 pb-3 md:pr-8">
    <CustomSelect
      id="filtro-operacion"
      label="Operación"
      placeholder="Todas"
      options={opcionesOperacion}
    />
  </div>

  <!-- Tipo de Propiedad -->
  <div class="flex-1 flex flex-col border-b border-brand-dark/20 pb-3 md:px-8">
    <CustomSelect
      id="filtro-tipo"
      label="Tipo de Propiedad"
      placeholder="Todos"
      options={opcionesTipo}
    />
  </div>

  <!-- Ubicación -->
  <div class="flex-1 flex flex-col border-b border-brand-dark/20 pb-3 md:px-8">
    <CustomSelect
      id="filtro-ciudad"
      label="Ubicación"
      placeholder="Todas las Ciudades"
      options={opcionesCiudad}
    />
  </div>

  <!-- Botón Aplicar Filtros (Dark, rectangular) -->
  <button
    id="filtro-buscar-btn"
    type="button"
    class="btn btn-dark py-4 px-8 flex items-center justify-center gap-2.5 cursor-pointer md:ml-8 mt-4 md:mt-0 whitespace-nowrap"
  >
    <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <line x1="4" x2="20" y1="6" y2="6"/>
      <line x1="8" x2="16" y1="12" y2="12"/>
      <line x1="12" x2="12" y1="18" y2="18"/>
    </svg>
    Aplicar Filtros
  </button>

</div>
