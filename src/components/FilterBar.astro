---
// FilterBar.astro - Componente premium para filtrar propiedades en la página del catálogo con dropdowns personalizados
import propiedadesRaw from '../data/propiedades.json';
import CustomSelect from './CustomSelect.astro';

// Obtener ciudades únicas
const ciudades = [...new Set(propiedadesRaw.filter(p => p.disponible).map(p => p.ciudad))].sort();

const opcionesOperacion = [
  { value: 'alquiler', label: 'Alquiler' },
  { value: 'venta', label: 'Venta' }
];

const opcionesTipo = [
  { value: 'casa', label: 'Casa' },
  { value: 'departamento', label: 'Departamento' },
  { value: 'local', label: 'Local Comercial' }
];

const opcionesCiudad = ciudades.map(c => ({ value: c, label: c }));
---

<div class="w-full bg-white border border-brand-sand rounded-2xl p-4 md:p-3 shadow-sm flex flex-col md:flex-row items-stretch md:items-center gap-3 select-none animate-fadeInUp z-20">
  <!-- Operación -->
  <div class="flex-1 flex flex-col gap-0.5 border-b md:border-b-0 md:border-r border-brand-sand pb-3 md:pb-0 md:pr-3">
    <CustomSelect 
      id="filtro-operacion" 
      label="Operación" 
      placeholder="Todas" 
      options={opcionesOperacion} 
    />
  </div>

  <!-- Tipo de Inmueble -->
  <div class="flex-1 flex flex-col gap-0.5 border-b md:border-b-0 md:border-r border-brand-sand pb-3 md:pb-0 md:px-3">
    <CustomSelect 
      id="filtro-tipo" 
      label="Tipo" 
      placeholder="Todos los Tipos" 
      options={opcionesTipo} 
    />
  </div>

  <!-- Ciudad -->
  <div class="flex-1 flex flex-col gap-0.5 border-b md:border-b-0 border-brand-sand pb-3 md:pb-0 md:px-3">
    <CustomSelect 
      id="filtro-ciudad" 
      label="Ciudad" 
      placeholder="Todas las Ciudades" 
      options={opcionesCiudad} 
    />
  </div>

  <!-- Botón de Filtrar -->
  <button 
    id="filtro-buscar-btn"
    type="button"
    class="btn btn-primary bg-brand-sage hover:bg-brand-dark text-white rounded-xl md:rounded-lg py-2.5 px-6 flex items-center justify-center gap-2 cursor-pointer font-bold text-xs uppercase tracking-wider transition-all md:self-center"
  >
    <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
      <polygon points="22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3"/>
    </svg>
    Filtrar
  </button>
</div>
