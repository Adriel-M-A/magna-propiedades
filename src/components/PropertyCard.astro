---
// PropertyCard.astro — Variante 'home' (fondo blanco) y 'catalog' (fondo cream, sombra)
export interface Propiedad {
  id: string;
  disponible: boolean;
  destacada?: boolean;
  fecha_carga: string;
  operacion: 'alquiler' | 'venta';
  tipo: 'casa' | 'departamento' | 'local';
  titulo: string;
  direccion: string;
  ciudad: string;
  barrio: string;
  caracteristicas_criticas: {
    dormitorios: number | null;
    banos: number | null;
    superficie_m2: number | null;
  };
  comodidades_destacadas: string[];
  descripcion_general: string;
  contacto: {
    telefono: string;
    mensaje_whatsapp: string;
  };
  imagenes: {
    principal: string | null;
    galeria: string[];
  };
}

interface Props {
  propiedad: Propiedad;
  index?: number;
  variant?: 'home' | 'catalog';
}

const { propiedad, index = 0, variant = 'home' } = Astro.props;
const delayClass = index > 0 ? `reveal-delay-${Math.min(index, 3)}` : '';

// 'home': card sin borde, padding solo en título y ubicación.
// 'catalog': card sobre fondo crema → sombra suave + borde, padding en todo el contenido interior.
const cardClass =
  variant === 'catalog'
    ? 'bg-white border border-brand-sand shadow-md hover:shadow-lg'
    : 'bg-white';

const innerContainerClass = variant === 'catalog' ? 'px-5' : '';
const textPaddingClass = variant === 'home' ? 'px-5' : '';
---

<article
  class={`reveal ${delayClass} flex flex-col transition-all duration-300 ${cardClass}`}
  data-operacion={propiedad.operacion}
  data-tipo={propiedad.tipo}
  data-ciudad={propiedad.ciudad}
>
  <!-- FILA 1: Imagen Cuadrada con Badge de Operación -->
  <a
    href={`/propiedades/${propiedad.id}`}
    class="block relative overflow-hidden aspect-square select-none group outline-none"
    aria-label={`Ver detalles de ${propiedad.titulo}`}
  >
    {propiedad.imagenes.principal ? (
      <img
        src={propiedad.imagenes.principal}
        alt={propiedad.titulo}
        class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
        loading="lazy"
        decoding="async"
      />
    ) : (
      <div class="w-full h-full bg-brand-sand/40 flex flex-col items-center justify-center gap-3">
        <svg class="w-8 h-8 text-brand-dark/25" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
          <polyline points="9 22 9 12 15 12 15 22"/>
        </svg>
        <span class="text-[9px] font-bold uppercase tracking-widest text-brand-dark/30">Sin Imagen</span>
      </div>
    )}

    <!-- Badge de Operación superpuesto -->
    <span class={`absolute top-3 left-3 px-3 py-1 text-[9px] font-bold uppercase tracking-widest text-white ${propiedad.operacion === 'venta' ? 'bg-brand-sage' : 'bg-brand-dark'}`}>
      {propiedad.operacion === 'alquiler' ? 'Alquiler' : 'Venta'}
    </span>
  </a>

  <!-- Filas 2–5: Contenedor principal de info -->
  <div class={`flex flex-col flex-1 pt-4 pb-5 gap-0 ${innerContainerClass}`}>

    <!-- FILA 2: Título -->
    <a href={`/propiedades/${propiedad.id}`} class={`no-underline group outline-none ${textPaddingClass}`}>
      <h3 class="text-lg sm:text-xl font-serif font-bold text-brand-dark group-hover:text-brand-sage transition-colors leading-tight">
        {propiedad.titulo}
      </h3>
    </a>

    <!-- FILA 3: Dirección / Ciudad -->
    <p class={`mt-1.5 text-xs text-brand-dark/55 font-medium ${textPaddingClass}`}>
      {propiedad.barrio ? `${propiedad.barrio}, ` : ''}{propiedad.ciudad}
    </p>

    <!-- FILA 4: Amenities -->
    <div class="mt-4 pt-4 border-t border-brand-sand flex items-center gap-5 text-xs text-brand-dark/70 font-semibold">
      {propiedad.caracteristicas_criticas.dormitorios !== null && (
        <span class="flex items-center gap-1.5">
          <svg class="w-4 h-4 text-brand-dark/40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75">
            <path d="M2 4v16"/><path d="M2 8h18a2 2 0 0 1 2 2v10"/><path d="M2 17h20"/><path d="M6 8v9"/>
          </svg>
          {propiedad.caracteristicas_criticas.dormitorios} Dorm.
        </span>
      )}
      {propiedad.caracteristicas_criticas.banos !== null && (
        <span class="flex items-center gap-1.5">
          <svg class="w-4 h-4 text-brand-dark/40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75">
            <path d="M9 6 6.5 3.5a1.5 1.5 0 0 0-1-.5C4.683 3 4 3.683 4 4.5V17a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-5"/>
            <line x1="2" x2="22" y1="12" y2="12"/>
          </svg>
          {propiedad.caracteristicas_criticas.banos} {propiedad.caracteristicas_criticas.banos === 1 ? 'Baño' : 'Baños'}
        </span>
      )}
      {propiedad.caracteristicas_criticas.superficie_m2 !== null && (
        <span class="flex items-center gap-1.5">
          <svg class="w-4 h-4 text-brand-dark/40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75">
            <path d="M3 3h7v7H3z"/><path d="M14 3h7v7h-7z"/><path d="M14 14h7v7h-7z"/><path d="M3 14h7v7H3z"/>
          </svg>
          {propiedad.caracteristicas_criticas.superficie_m2} m²
        </span>
      )}
    </div>

    <!-- FILA 5: Botón de Acción -->
    <div class="mt-5">
      <a
        href={`/propiedades/${propiedad.id}`}
        class="btn btn-outline w-full justify-center py-3 text-[10px]"
        aria-label={`Ver detalles de ${propiedad.titulo}`}
      >
        Ver Detalles
      </a>
    </div>
  </div>
</article>
