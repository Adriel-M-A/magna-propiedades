---
// Header.astro - Sticky Glassmorphic Premium Header navigation
---

<header class="site-header fixed top-0 left-0 right-0 z-50 glass-header select-none">
  <div class="container-main header-inner">
    <!-- Logo Tradicional de Lujo -->
    <a href="/" class="header-logo flex items-center gap-2 group" aria-label="Magna Propiedades - Inicio">
      <span class="font-serif text-xl sm:text-2xl font-bold text-brand-dark tracking-wide group-hover:text-brand-sage transition-colors">
        Magna Propiedades
      </span>
    </a>

    <!-- Desktop Navigation Links -->
    <nav class="header-nav hidden md:flex items-center gap-1.5" aria-label="Navegación principal">
      <a href="/" class="nav-link">Inicio</a>
      <a href="/catalogo" class="nav-link">Catálogo</a>
      <a href="/#servicios" class="nav-link">Servicios</a>
      <a href="/#integrales" class="nav-link">Contacto</a>
    </nav>

    <!-- Desktop CTA: Botón "Ver Propiedades" en formato píldora -->
    <a 
      href="/catalogo" 
      class="btn btn-primary bg-brand-sage hover:bg-brand-dark text-white rounded-full px-5 py-2 text-xs font-bold uppercase tracking-wider hidden md:inline-flex shadow-sm transition-all"
      aria-label="Ver todas las propiedades del catálogo"
    >
      Ver Propiedades
    </a>

    <!-- Mobile Hamburger Button -->
    <button
      id="mobile-menu-btn"
      class="hamburger-btn md:hidden flex flex-col justify-center items-center gap-1.5 w-10 h-10 border border-brand-sand bg-white/50 backdrop-blur rounded-lg cursor-pointer transition-all"
      aria-label="Abrir menú de navegación"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <span class="hamburger-line"></span>
      <span class="hamburger-line"></span>
      <span class="hamburger-line"></span>
    </button>
  </div>

  <!-- Mobile Dropdown Menu -->
  <div id="mobile-menu" class="mobile-menu md:hidden overflow-hidden max-h-0 bg-white border-t border-brand-sand transition-all duration-300" aria-hidden="true">
    <nav class="flex flex-col py-2" aria-label="Menú móvil">
      <a href="/" class="mobile-nav-link">Inicio</a>
      <a href="/catalogo" class="mobile-nav-link">Catálogo</a>
      <a href="/#servicios" class="mobile-nav-link">Servicios</a>
      <a href="/#integrales" class="mobile-nav-link">Contacto</a>
      
      <div class="p-4 border-t border-brand-sand/50">
        <a 
          href="/catalogo" 
          class="btn btn-primary bg-brand-sage w-full justify-center text-xs font-bold uppercase tracking-wider py-3 shadow-sm rounded-lg"
        >
          Ver Propiedades
        </a>
      </div>
    </nav>
  </div>
</header>

<!-- Espaciador para evitar solapamiento debido al header fijo -->
<div class="h-16 w-full select-none" aria-hidden="true"></div>

<style>
  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 64px;
    gap: 1rem;
  }

  /* Links de escritorio */
  .nav-link {
    padding: 0.45rem 1rem;
    border-radius: var(--radius-lg);
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-brand-dark);
    text-decoration: none;
    transition: all 0.2s ease;
  }

  .nav-link:hover {
    color: var(--color-brand-sage);
    background-color: var(--color-brand-sand);
  }

  /* Hamburger lines */
  .hamburger-line {
    display: block;
    width: 20px;
    height: 1.5px;
    background-color: var(--color-brand-dark);
    border-radius: 1px;
    transition: transform 0.25s, opacity 0.2s;
  }

  /* Hamburguesa abierta (X) */
  .hamburger-btn.is-open .hamburger-line:nth-child(1) {
    transform: translateY(5px) rotate(45deg);
  }
  .hamburger-btn.is-open .hamburger-line:nth-child(2) {
    opacity: 0;
  }
  .hamburger-btn.is-open .hamburger-line:nth-child(3) {
    transform: translateY(-5px) rotate(-45deg);
  }

  /* Mobile menu rules */
  .mobile-menu.is-open {
    max-height: 280px;
  }

  .mobile-nav-link {
    display: block;
    padding: 0.85rem 1.5rem;
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--color-brand-dark);
    text-decoration: none;
    transition: all 0.2s ease;
  }

  .mobile-nav-link:hover {
    color: var(--color-brand-sage);
    background-color: var(--color-brand-cream);
    padding-left: 1.75rem;
  }
</style>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');

  btn?.addEventListener('click', () => {
    const isOpen = menu?.classList.toggle('is-open');
    btn.classList.toggle('is-open');
    btn.setAttribute('aria-expanded', String(isOpen));
    menu?.setAttribute('aria-hidden', String(!isOpen));
  });

  // Cerrar menú al hacer clic en un enlace
  menu?.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => {
      menu.classList.remove('is-open');
      btn?.classList.remove('is-open');
      btn?.setAttribute('aria-expanded', 'false');
      menu.setAttribute('aria-hidden', 'true');
    });
  });
</script>
