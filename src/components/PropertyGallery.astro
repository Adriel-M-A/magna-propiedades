---
// PropertyGallery.astro - Componente premium para la visualización de imágenes de propiedad (Sin modal de zoom, mudado al root de [id].astro)

interface Props {
  imagenes: {
    principal: string | null;
    galeria: string[];
  };
  titulo: string;
}

const { imagenes, titulo } = Astro.props;

// Combinar la imagen principal y las de la galería en un único listado
const todasLasImagenes = [
  ...(imagenes.principal ? [imagenes.principal] : []),
  ...(imagenes.galeria ?? [])
];

// Si no hay imágenes reales, a modo de testeo simulamos 4 placeholders elegantes de "sin imagen"
const mockImagenes = ['placeholder-1', 'placeholder-2', 'placeholder-3', 'placeholder-4'];
const imagenesParaMostrar = todasLasImagenes.length > 0 ? todasLasImagenes : mockImagenes;

const hayImagenes = true; // Consideramos siempre true para habilitar el testeo de grilla/carrusel
const cantidadRestante = imagenesParaMostrar.length > 3 ? imagenesParaMostrar.length - 2 : 0;
---

<div class="w-full relative select-none">
  {hayImagenes ? (
    <div class="w-full">
      <!-- ==========================================
           VISTA MÓVIL: Swiper Carousel
           ========================================== -->
      <div class="block md:hidden w-full aspect-[4/3] rounded-2xl border border-brand-sand overflow-hidden shadow-sm bg-white p-1">
        <div class="swiper w-full h-full rounded-xl overflow-hidden" id="mobile-gallery-swiper">
          <div class="swiper-wrapper">
            {imagenesParaMostrar.map((src, i) => (
              <div class="swiper-slide w-full h-full">
                {src.startsWith('placeholder') ? (
                  <div class="w-full h-full flex flex-col items-center justify-center gap-2 bg-gradient-to-br from-brand-cream to-brand-sand text-brand-sage">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round" class="w-10 h-10 opacity-40">
                      <path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/>
                      <polyline points="9 22 9 12 15 12 15 22"/>
                    </svg>
                    <span class="text-[10px] font-bold uppercase tracking-wider opacity-50">Sin Imagen Disponible</span>
                  </div>
                ) : (
                  <img 
                    src={src} 
                    alt={`${titulo} - Foto ${i + 1}`} 
                    class="w-full h-full object-cover"
                    loading={i === 0 ? "eager" : "lazy"}
                  />
                )}
              </div>
            ))}
          </div>
          <div class="swiper-pagination !bottom-3"></div>
        </div>
      </div>

      <!-- ==========================================
           VISTA ESCRITORIO: Grilla Asimétrica Premium (Aspecto Cinematográfico 21/9)
           ========================================== -->
      <div class="hidden md:block w-full">
        <div class="grid grid-cols-12 gap-3 aspect-[21/9] w-full rounded-2xl overflow-hidden shadow-sm border border-brand-sand bg-white p-2">
          <!-- Columna Izquierda: Imagen Principal Grande -->
          <div class="col-span-8 h-full rounded-xl overflow-hidden cursor-pointer relative group" data-gallery-trigger="0">
            <div class="absolute inset-0 bg-brand-dark/0 group-hover:bg-brand-dark/10 transition-all duration-300 z-10"></div>
            {imagenesParaMostrar[0].startsWith('placeholder') ? (
              <div class="w-full h-full flex flex-col items-center justify-center gap-3 bg-gradient-to-br from-brand-cream to-brand-sand text-brand-sage border border-brand-sand/50">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" class="w-12 h-12 opacity-40">
                  <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
                  <polyline points="9 22 9 12 15 12 15 22"/>
                </svg>
                <span class="text-xs font-bold uppercase tracking-widest opacity-50">Sin Imagen Disponible</span>
              </div>
            ) : (
              <img 
                src={imagenesParaMostrar[0]} 
                alt={`${titulo} - Imagen principal`}
                class="w-full h-full object-cover group-hover:scale-[1.02] transition-transform duration-500"
                loading="eager"
              />
            )}
          </div>

          <!-- Columna Derecha: Dos Imágenes de Detalle Apiladas -->
          <div class="col-span-4 flex flex-col gap-3 h-full overflow-hidden">
            <!-- Detalle Superior (Foto 2) -->
            <div class="flex-1 rounded-xl overflow-hidden cursor-pointer relative group" data-gallery-trigger="1">
              <div class="absolute inset-0 bg-brand-dark/0 group-hover:bg-brand-dark/10 transition-all duration-300 z-10"></div>
              {imagenesParaMostrar[1].startsWith('placeholder') ? (
                <div class="w-full h-full flex flex-col items-center justify-center gap-2 bg-gradient-to-br from-brand-cream to-brand-sand text-brand-sage border border-brand-sand/50">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round" class="w-8 h-8 opacity-40">
                    <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
                    <polyline points="9 22 9 12 15 12 15 22"/>
                  </svg>
                  <span class="text-[9px] font-bold uppercase tracking-wider opacity-50">Sin Imagen</span>
                </div>
              ) : (
                <img 
                  src={imagenesParaMostrar[1] || imagenesParaMostrar[0]} 
                  alt={`${titulo} - Detalle interior`}
                  class="w-full h-full object-cover group-hover:scale-[1.02] transition-transform duration-500"
                  loading="lazy"
                />
              )}
            </div>

            <!-- Detalle Inferior (Foto 3 con Overlay) -->
            <div class="flex-1 rounded-xl overflow-hidden cursor-pointer relative group" data-gallery-trigger="2">
              {cantidadRestante > 0 ? (
                <div class="absolute inset-0 bg-brand-dark/40 group-hover:bg-brand-dark/50 transition-all duration-300 z-10 flex items-center justify-center">
                  <span class="text-white font-serif font-bold text-lg tracking-wider">
                    +{cantidadRestante} fotos
                  </span>
                </div>
              ) : (
                <div class="absolute inset-0 bg-brand-dark/0 group-hover:bg-brand-dark/10 transition-all duration-300 z-10"></div>
              )}
              {imagenesParaMostrar[2].startsWith('placeholder') ? (
                <div class="w-full h-full flex flex-col items-center justify-center gap-2 bg-gradient-to-br from-brand-cream to-brand-sand text-brand-sage border border-brand-sand/50">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round" class="w-8 h-8 opacity-40">
                    <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
                    <polyline points="9 22 9 12 15 12 15 22"/>
                  </svg>
                  <span class="text-[9px] font-bold uppercase tracking-wider opacity-50">Sin Imagen</span>
                </div>
              ) : (
                <img 
                  src={imagenesParaMostrar[2] || imagenesParaMostrar[0]} 
                  alt={`${titulo} - Detalle de terminaciones`}
                  class="w-full h-full object-cover group-hover:scale-[1.02] transition-transform duration-500"
                  loading="lazy"
                />
              )}
            </div>
          </div>
        </div>
      </div>
    </div>
  ) : (
    <div class="property-image-placeholder rounded-2xl border border-brand-sand aspect-[21/9] w-full flex flex-col items-center justify-center gap-3 bg-white p-2">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" class="w-12 h-12 text-brand-sage opacity-50">
        <rect width="18" height="18" x="3" y="3" rx="2" ry="2"/>
        <circle cx="9" cy="9" r="2"/>
        <path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"/>
      </svg>
      <span class="text-xs font-semibold text-brand-sage tracking-widest uppercase opacity-60">
        Sin imagen disponible
      </span>
    </div>
  )}
</div>

<script>
  // Inicialización de Swiper móvil si aplica
  const mobileSwiperEl = document.getElementById('mobile-gallery-swiper');
  if (mobileSwiperEl) {
    import('swiper').then(({ default: Swiper }) => {
      import('swiper/modules').then(({ Pagination }) => {
        new Swiper('#mobile-gallery-swiper', {
          modules: [Pagination],
          pagination: {
            el: '#mobile-gallery-swiper .swiper-pagination',
            clickable: true,
          },
          loop: true,
          grabCursor: true,
        });
      });
    });
  }
</script>
