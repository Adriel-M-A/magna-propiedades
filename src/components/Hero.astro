---
// Hero.astro - Componente premium para la sección principal de la página de inicio con buscador personalizado (Diseño Tipográfico sin Imágenes)
import CustomSelect from './CustomSelect.astro';
import propiedadesRaw from '../data/propiedades.json';

const ciudades = [...new Set(propiedadesRaw.filter(p => p.disponible).map(p => p.ciudad))].sort();

const opcionesOperacion = [
  { value: 'alquiler', label: 'Alquiler' },
  { value: 'venta', label: 'Venta' }
];

const opcionesTipo = [
  { value: 'casa', label: 'Casa' },
  { value: 'departamento', label: 'Departamento' },
  { value: 'local', label: 'Local Comercial' }
];

const opcionesCiudad = ciudades.map(c => ({ value: c, label: c }));
---

<div class="relative w-full min-h-[550px] md:min-h-[650px] flex items-center justify-center bg-brand-cream select-none px-4 py-20">
  
  <div class="relative z-20 flex flex-col items-center w-full max-w-4xl mx-auto gap-8 md:gap-12">
    <!-- Título principal tipográfico -->
    <div class="text-center animate-fadeInUp flex flex-col items-center gap-6">
      <span class="inline-block text-xs md:text-sm font-bold text-brand-sage uppercase tracking-[0.2em]">
        Inmobiliaria Exclusiva
      </span>
      <h1 class="text-5xl md:text-7xl font-bold font-serif text-brand-dark leading-none tracking-tight uppercase">
        Magna
      </h1>
      <div class="w-16 h-px bg-brand-dark/20"></div>
      <p class="text-sm md:text-base text-brand-dark/70 leading-relaxed max-w-lg font-medium">
        Líderes en servicios inmobiliarios en Trelew y la región. Descubra propiedades exclusivas curadas con el más alto estándar de excelencia.
      </p>
    </div>

    <!-- Buscador Integrado -->
    <div class="w-full bg-white rounded-none border border-brand-sand p-4 md:p-3 shadow-sm flex flex-col md:flex-row items-stretch md:items-center gap-3 animate-fadeInUp delay-200">
      
      <div class="flex-1 flex flex-col px-4 gap-1 border-b md:border-b-0 md:border-r border-brand-sand pb-3 md:pb-0">
        <CustomSelect id="hero-operacion" label="Operación" placeholder="Todas" options={opcionesOperacion} />
      </div>

      <div class="flex-1 flex flex-col px-4 gap-1 border-b md:border-b-0 md:border-r border-brand-sand pb-3 md:pb-0">
        <CustomSelect id="hero-tipo" label="Inmueble" placeholder="Todos los Tipos" options={opcionesTipo} />
      </div>

      <div class="flex-1 flex flex-col px-4 gap-1 pb-3 md:pb-0">
        <CustomSelect id="hero-ciudad" label="Ciudad" placeholder="Todas las Ciudades" options={opcionesCiudad} />
      </div>

      <button id="hero-buscar-btn" type="button" class="btn btn-dark w-full md:w-auto py-4 md:py-3 px-8 flex items-center justify-center gap-2 cursor-pointer">
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="11" cy="11" r="8"/>
          <line x1="21" x2="16.65" y1="21" y2="16.65"/>
        </svg>
        Buscar
      </button>
    </div>
  </div>
</div>

<script>
  const buscarBtn = document.getElementById('hero-buscar-btn');
  buscarBtn?.addEventListener('click', () => {
    const op = (document.getElementById('hero-operacion') as HTMLInputElement).value;
    const tipo = (document.getElementById('hero-tipo') as HTMLInputElement).value;
    const ciudad = (document.getElementById('hero-ciudad') as HTMLInputElement).value;
    
    const params = new URLSearchParams();
    if (op) params.append('operacion', op);
    if (tipo) params.append('tipo', tipo);
    if (ciudad) params.append('ciudad', ciudad);
    
    window.location.href = `/catalogo?${params.toString()}`;
  });
</script>
