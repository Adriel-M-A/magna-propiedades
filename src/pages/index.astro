---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import PropertyCard from '../components/PropertyCard.astro';
import ServicesProfessionals from '../components/ServicesProfessionals.astro';
import ServicesIntegrales from '../components/ServicesIntegrales.astro';
import Footer from '../components/Footer.astro';
import type { Propiedad } from '../components/PropertyCard.astro';

import propiedadesRaw from '../data/propiedades.json';

// Máximo 3 propiedades disponibles y destacadas, ordenadas por fecha descendente
const propiedadesDestacadas: Propiedad[] = (propiedadesRaw as Propiedad[])
  .filter((p) => p.disponible && p.destacada)
  .sort((a, b) => new Date(b.fecha_carga).getTime() - new Date(a.fecha_carga).getTime())
  .slice(0, 3);
---

<Layout
  title="Magna Propiedades | Inmobiliaria de Vanguardia en Chubut"
  description="Catálogo exclusivo de propiedades en Trelew, Rawson y Puerto Madryn. Consultas directas y cotización 100% privada por WhatsApp."
>
  <Header />

  <!-- ==============================
       HERO: Tipografía + Buscador
       ============================== -->
  <Hero />

  <!-- ==============================
       PROPIEDADES DESTACADAS
       ============================== -->
  <section class="py-20 bg-white">
    <div class="container-main">
      <!-- Encabezado: label + título y enlace en misma fila, sin separador -->
      <div class="mb-12">
        <span class="text-[10px] font-bold text-brand-sage uppercase tracking-[0.25em]">
          Selección Magna
        </span>
        <div class="flex flex-col sm:flex-row sm:items-end justify-between gap-4 mt-2">
          <h2 class="text-3xl sm:text-4xl lg:text-5xl font-serif font-bold text-brand-dark leading-none">
            Propiedades Destacadas
          </h2>
          <a
            href="/catalogo"
            class="inline-flex items-center gap-2 text-[10px] font-bold uppercase tracking-widest text-brand-dark hover:text-brand-sage transition-colors whitespace-nowrap self-start sm:self-end pb-1"
          >
            Ver Catálogo Completo
            <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Grilla de Tarjetas: separadas con gap, no divididas con bordes -->
      {propiedadesDestacadas.length > 0 ? (
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8 lg:gap-10">
          {propiedadesDestacadas.map((p, i) => (
            <PropertyCard propiedad={p} index={i} />
          ))}
        </div>
      ) : (
        <div class="text-center py-16 border border-brand-sand text-brand-dark/40 text-xs font-semibold uppercase tracking-widest reveal">
          No hay propiedades destacadas en este momento.
        </div>
      )}
    </div>
  </section>

  <!-- ==============================
       SERVICIOS PROFESIONALES
       ============================== -->
  <ServicesProfessionals />

  <!-- ==============================
       SERVICIOS INTEGRALES
       ============================== -->
  <ServicesIntegrales variant="homepage" background="cream" />

  <Footer />
</Layout>
